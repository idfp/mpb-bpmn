<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <process id="ProsesDToBe" name="To-Be: Koordinasi Alumni dan Tracer Study" isExecutable="true" camunda:historyTimeToLive="180">
    <laneSet id="laneSet_1">
      <lane id="lane_dosenpa" name="Dosen PA">
        <flowNodeRef>task_tindak_lanjut</flowNodeRef>
      </lane>
      <lane id="lane_sistem" name="Sistem Portal">
        <flowNodeRef>svc_kirim_link</flowNodeRef>
        <flowNodeRef>svc_kirim_pengingat</flowNodeRef>
        <flowNodeRef>svc_kirim_undangan</flowNodeRef>
      </lane>
      <lane id="lane_wdiii" name="WD III (Wakil Dekan Kemahasiswaan)">
        <flowNodeRef>task_inisiasi</flowNodeRef>
        <flowNodeRef>task_monitor</flowNodeRef>
        <flowNodeRef>task_request_rekap</flowNodeRef>
        <flowNodeRef>task_analisis</flowNodeRef>
        <flowNodeRef>task_persiapkan_forum</flowNodeRef>
        <flowNodeRef>task_pimpin_forum</flowNodeRef>
        <flowNodeRef>gw_merge</flowNodeRef>
        <flowNodeRef>task_rtm</flowNodeRef>
        <flowNodeRef>task_lapor</flowNodeRef>
        <flowNodeRef>start_1</flowNodeRef>
        <flowNodeRef>gw_respons</flowNodeRef>
        <flowNodeRef>gw_kurikulum</flowNodeRef>
        <flowNodeRef>end_1</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="start_1" name="Periode Pengumpulan&#10;Data Tracer Study">
      <outgoing>sf_start_inisiasi</outgoing>
    </startEvent>
    <userTask id="task_inisiasi" name="Inisiasi &#38; Koordinasi&#10;Tracer Study dengan CDE" camunda:assignee="wd3">
      <incoming>sf_start_inisiasi</incoming>
      <outgoing>sf_inisiasi_link</outgoing>
    </userTask>
    <serviceTask id="svc_kirim_link" name="Kirim Notifikasi&#10;Link Tracer ke Alumni">
      <extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">http://217.217.254.115:8900/notify</camunda:inputParameter>
            <camunda:inputParameter name="method">POST</camunda:inputParameter>
            <camunda:inputParameter name="payload">{"recipient":"alumni_all","type":"tracer_link","processId":"${execution.processInstanceId}"}</camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">application/json</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </extensionElements>
      <incoming>sf_inisiasi_link</incoming>
      <outgoing>sf_link_monitor</outgoing>
    </serviceTask>
    <userTask id="task_monitor" name="Monitor Respons Rate&#10;Tracer di Portal" camunda:assignee="wd3">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="responsCukup" label="Apakah respons cukup?" type="boolean" defaultValue="false" />
        </camunda:formData>
      </extensionElements>
      <incoming>sf_link_monitor</incoming>
      <incoming>sf_pengingat_back</incoming>
      <outgoing>sf_monitor_gw</outgoing>
    </userTask>
    <exclusiveGateway id="gw_respons" name="Respons Rate&#10;Cukup?">
      <incoming>sf_monitor_gw</incoming>
      <outgoing>sf_respons_tidak</outgoing>
      <outgoing>sf_respons_ya</outgoing>
    </exclusiveGateway>
    <userTask id="task_tindak_lanjut" name="Tindak Lanjut Alumni&#10;Non-Responden (per PA)" camunda:candidateGroups="dosen_pa">
      <incoming>sf_respons_tidak</incoming>
      <outgoing>sf_tindak_pengingat</outgoing>
    </userTask>
    <serviceTask id="svc_kirim_pengingat" name="Kirim Notifikasi&#10;Pengingat ke Alumni">
      <extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">http://217.217.254.115:8900/notify</camunda:inputParameter>
            <camunda:inputParameter name="method">POST</camunda:inputParameter>
            <camunda:inputParameter name="payload">{"recipient":"alumni_nonresponden","type":"tracer_reminder","processId":"${execution.processInstanceId}"}</camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">application/json</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </extensionElements>
      <incoming>sf_tindak_pengingat</incoming>
      <outgoing>sf_pengingat_back</outgoing>
    </serviceTask>
    <userTask id="task_request_rekap" name="Request &#38; Terima&#10;Rekap Data dari CDE" camunda:assignee="wd3">
      <incoming>sf_respons_ya</incoming>
      <outgoing>sf_request_analisis</outgoing>
    </userTask>
    <userTask id="task_analisis" name="Analisis Data&#10;Tracer Study" camunda:assignee="wd3">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="tahunPeninjauan" label="Apakah tahun ini termasuk tahun peninjauan kurikulum?" type="boolean" defaultValue="false" />
        </camunda:formData>
      </extensionElements>
      <incoming>sf_request_analisis</incoming>
      <outgoing>sf_analisis_gw</outgoing>
    </userTask>
    <exclusiveGateway id="gw_kurikulum" name="Tahun Peninjauan&#10;Kurikulum? (2 thn)">
      <incoming>sf_analisis_gw</incoming>
      <outgoing>sf_kurikulum_ya</outgoing>
      <outgoing>sf_kurikulum_tidak</outgoing>
    </exclusiveGateway>
    <userTask id="task_persiapkan_forum" name="Persiapkan Forum&#10;Peninjauan Kurikulum" camunda:assignee="wd3">
      <incoming>sf_kurikulum_ya</incoming>
      <outgoing>sf_persiapkan_undangan</outgoing>
    </userTask>
    <serviceTask id="svc_kirim_undangan" name="Kirim Undangan Forum&#10;ke Alumni &#38; Mitra Industri">
      <extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">http://217.217.254.115:8900/notify</camunda:inputParameter>
            <camunda:inputParameter name="method">POST</camunda:inputParameter>
            <camunda:inputParameter name="payload">{"recipient":"alumni_and_mitra","type":"forum_invitation","processId":"${execution.processInstanceId}"}</camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">application/json</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </extensionElements>
      <incoming>sf_persiapkan_undangan</incoming>
      <outgoing>sf_undangan_pimpin</outgoing>
    </serviceTask>
    <userTask id="task_pimpin_forum" name="Pimpin Forum Peninjauan&#10;Kurikulum &#38; Koordinasi Alumni" camunda:assignee="wd3">
      <incoming>sf_undangan_pimpin</incoming>
      <outgoing>sf_pimpin_merge</outgoing>
    </userTask>
    <exclusiveGateway id="gw_merge" name="">
      <incoming>sf_pimpin_merge</incoming>
      <incoming>sf_kurikulum_tidak</incoming>
      <outgoing>sf_merge_rtm</outgoing>
    </exclusiveGateway>
    <userTask id="task_rtm" name="Bahas Hasil Tracer di RTM&#10;&#38; Dokumentasikan" camunda:assignee="wd3">
      <incoming>sf_merge_rtm</incoming>
      <outgoing>sf_rtm_lapor</outgoing>
    </userTask>
    <userTask id="task_lapor" name="Lapor ke Wadek III&#10;&#38; Input ke LAKIN" camunda:assignee="wd3">
      <incoming>sf_rtm_lapor</incoming>
      <outgoing>sf_lapor_end</outgoing>
    </userTask>
    <endEvent id="end_1" name="Data Tracer Selesai&#10;Dikumpulkan &#38; Dilaporkan">
      <incoming>sf_lapor_end</incoming>
    </endEvent>
    <sequenceFlow id="sf_start_inisiasi" sourceRef="start_1" targetRef="task_inisiasi" />
    <sequenceFlow id="sf_inisiasi_link" sourceRef="task_inisiasi" targetRef="svc_kirim_link" />
    <sequenceFlow id="sf_link_monitor" sourceRef="svc_kirim_link" targetRef="task_monitor" />
    <sequenceFlow id="sf_monitor_gw" sourceRef="task_monitor" targetRef="gw_respons" />
    <sequenceFlow id="sf_respons_tidak" name="Tidak" sourceRef="gw_respons" targetRef="task_tindak_lanjut">
      <conditionExpression xsi:type="tFormalExpression">${responsCukup == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_respons_ya" name="Ya" sourceRef="gw_respons" targetRef="task_request_rekap">
      <conditionExpression xsi:type="tFormalExpression">${responsCukup == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_tindak_pengingat" sourceRef="task_tindak_lanjut" targetRef="svc_kirim_pengingat" />
    <sequenceFlow id="sf_pengingat_back" sourceRef="svc_kirim_pengingat" targetRef="task_monitor" />
    <sequenceFlow id="sf_request_analisis" sourceRef="task_request_rekap" targetRef="task_analisis" />
    <sequenceFlow id="sf_analisis_gw" sourceRef="task_analisis" targetRef="gw_kurikulum" />
    <sequenceFlow id="sf_kurikulum_ya" name="Ya" sourceRef="gw_kurikulum" targetRef="task_persiapkan_forum">
      <conditionExpression xsi:type="tFormalExpression">${tahunPeninjauan == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_kurikulum_tidak" name="Tidak" sourceRef="gw_kurikulum" targetRef="gw_merge">
      <conditionExpression xsi:type="tFormalExpression">${tahunPeninjauan == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_persiapkan_undangan" sourceRef="task_persiapkan_forum" targetRef="svc_kirim_undangan" />
    <sequenceFlow id="sf_undangan_pimpin" sourceRef="svc_kirim_undangan" targetRef="task_pimpin_forum" />
    <sequenceFlow id="sf_pimpin_merge" sourceRef="task_pimpin_forum" targetRef="gw_merge" />
    <sequenceFlow id="sf_merge_rtm" sourceRef="gw_merge" targetRef="task_rtm" />
    <sequenceFlow id="sf_rtm_lapor" sourceRef="task_rtm" targetRef="task_lapor" />
    <sequenceFlow id="sf_lapor_end" sourceRef="task_lapor" targetRef="end_1" />
    <textAnnotation id="ann_monitor">
      <text>WD III pantau respons rate via dashboard portal; menggantikan komunikasi informal tidak terstruktur</text>
    </textAnnotation>
    <association id="assoc_monitor" sourceRef="task_monitor" targetRef="ann_monitor" />
    <textAnnotation id="ann_pengingat">
      <text>Notifikasi pengingat otomatis via email/Telegram; menggantikan WA manual satu per satu ke alumni</text>
    </textAnnotation>
    <association id="assoc_pengingat" sourceRef="svc_kirim_pengingat" targetRef="ann_pengingat" />
    <textAnnotation id="ann_rtm">
      <text>Hasil RTM dan tindak lanjut didokumentasikan dalam sistem sebagai referensi penyusunan LAKIN</text>
    </textAnnotation>
    <association id="assoc_rtm" sourceRef="task_rtm" targetRef="ann_rtm" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="ProsesDToBe">
      <bpmndi:BPMNShape id="lane_wdiii_di" bpmnElement="lane_wdiii" isHorizontal="true">
