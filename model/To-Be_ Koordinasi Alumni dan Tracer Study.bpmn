      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf_lapor_end_di" bpmnElement="sf_lapor_end">
        <di:waypoint x="2440" y="259" />
        <di:waypoint x="2502" y="259" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="assoc_monitor_di" bpmnElement="assoc_monitor">
        <di:waypoint x="730" y="219" />
        <di:waypoint x="730" y="125" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="assoc_pengingat_di" bpmnElement="assoc_pengingat">
        <di:waypoint x="1080" y="430" />
        <di:waypoint x="1080" y="650" />
      </bpmndi:BPMNEdge>
