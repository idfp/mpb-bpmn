        <di:waypoint x="1140" y="400" />
        <di:waypoint x="1170" y="400" />
        <di:waypoint x="1170" y="269" />
        <di:waypoint x="1190" y="269" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf_konfirmasi_gw_di" bpmnElement="sf_konfirmasi_gw">
        <di:waypoint x="1310" y="269" />
        <di:waypoint x="1360" y="269" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf_mitra_tidak_di" bpmnElement="sf_mitra_tidak">
        <di:waypoint x="1385" y="244" />
        <di:waypoint x="1385" y="210" />
        <di:waypoint x="910" y="210" />
        <di:waypoint x="910" y="229" />
        <bpmndi:BPMNLabel>
