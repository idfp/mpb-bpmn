      <bpmndi:BPMNEdge id="sf_start_identifikasi_di" bpmnElement="sf_start_identifikasi">
        <di:waypoint x="278" y="269" />
        <di:waypoint x="310" y="269" />
      </bpmndi:BPMNEdge>
