<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <process id="ProsesEToBe" name="To-Be: Alur Kerjasama (PKS dan IA)" isExecutable="true" camunda:historyTimeToLive="180">
    <laneSet id="laneSet_1">
      <lane id="lane_fitri" name="Mbak Fitri (Staf Administrasi)">
        <flowNodeRef>task_catat_ia</flowNodeRef>
        <flowNodeRef>task_catat_pks</flowNodeRef>
      </lane>
      <lane id="lane_dekan" name="Dekan">
        <flowNodeRef>task_ttd_ia</flowNodeRef>
        <flowNodeRef>task_ttd_pks</flowNodeRef>
      </lane>
      <lane id="lane_sistem" name="Sistem Portal">
        <flowNodeRef>svc_kirim_draft_ia</flowNodeRef>
        <flowNodeRef>svc_kirim_draft_pks</flowNodeRef>
      </lane>
      <lane id="lane_wdiii" name="WD III (Wakil Dekan Kemahasiswaan)">
        <flowNodeRef>task_identifikasi</flowNodeRef>
        <flowNodeRef>task_inisiasi</flowNodeRef>
        <flowNodeRef>task_susun_ia</flowNodeRef>
        <flowNodeRef>task_konfirmasi_ia</flowNodeRef>
        <flowNodeRef>task_ajukan_ia_dekan</flowNodeRef>
        <flowNodeRef>task_dinas</flowNodeRef>
        <flowNodeRef>task_diskusi</flowNodeRef>
        <flowNodeRef>task_konfirmasi_pks</flowNodeRef>
        <flowNodeRef>task_ajukan_pks_dekan</flowNodeRef>
        <flowNodeRef>start_1</flowNodeRef>
        <flowNodeRef>gw_tertarik</flowNodeRef>
        <flowNodeRef>end_1</flowNodeRef>
        <flowNodeRef>gw_mitra_pks</flowNodeRef>
        <flowNodeRef>gw_lanjutan</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="start_1" name="Identifikasi Kebutuhan&#10;Kerjasama Baru">
      <outgoing>sf_start_identifikasi</outgoing>
    </startEvent>
    <userTask id="task_identifikasi" name="Identifikasi &#38; Seleksi&#10;Calon Mitra Kerjasama" camunda:assignee="wd3">
      <incoming>sf_start_identifikasi</incoming>
      <outgoing>sf_identifikasi_inisiasi</outgoing>
    </userTask>
    <userTask id="task_inisiasi" name="Inisiasi Kontak&#10;dengan Calon Mitra" camunda:assignee="wd3">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="mitraTertarik" label="Apakah mitra tertarik?" type="boolean" defaultValue="false" />
        </camunda:formData>
      </extensionElements>
      <incoming>sf_identifikasi_inisiasi</incoming>
      <outgoing>sf_inisiasi_gw</outgoing>
    </userTask>
    <exclusiveGateway id="gw_tertarik" name="Mitra&#10;Tertarik?">
      <incoming>sf_inisiasi_gw</incoming>
      <outgoing>sf_tertarik_tidak</outgoing>
      <outgoing>sf_tertarik_ya</outgoing>
    </exclusiveGateway>
    <endEvent id="end_ditolak" name="Mitra Tidak&#10;Tertarik">
      <incoming>sf_tertarik_tidak</incoming>
    </endEvent>
    <userTask id="task_diskusi" name="Diskusi Ruang Lingkup&#10;&#38; Susun Draft PKS" camunda:assignee="wd3">
      <incoming>sf_tertarik_ya</incoming>
      <incoming>sf_mitra_tidak</incoming>
      <outgoing>sf_diskusi_link</outgoing>
    </userTask>
    <serviceTask id="svc_kirim_draft_pks" name="Kirim Draft PKS&#10;ke Mitra">
      <extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">http://217.217.254.115:8900/notify</camunda:inputParameter>
            <camunda:inputParameter name="method">POST</camunda:inputParameter>
            <camunda:inputParameter name="payload">{"recipient":"mitra","type":"pks_draft","processId":"${execution.processInstanceId}"}</camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">application/json</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </extensionElements>
      <incoming>sf_diskusi_link</incoming>
      <outgoing>sf_link_konfirmasi</outgoing>
    </serviceTask>
    <userTask id="task_konfirmasi_pks" name="Konfirmasi Persetujuan&#10;&#38; TTD Mitra terhadap PKS" camunda:assignee="wd3">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="mitraSetuju" label="Apakah mitra menyetujui PKS?" type="boolean" defaultValue="false" />
        </camunda:formData>
      </extensionElements>
      <incoming>sf_link_konfirmasi</incoming>
      <outgoing>sf_konfirmasi_gw</outgoing>
    </userTask>
    <exclusiveGateway id="gw_mitra_pks" name="Mitra&#10;Setuju PKS?">
      <incoming>sf_konfirmasi_gw</incoming>
      <outgoing>sf_mitra_tidak</outgoing>
      <outgoing>sf_mitra_ya</outgoing>
    </exclusiveGateway>
    <userTask id="task_ajukan_pks_dekan" name="Ajukan PKS ke Dekan&#10;untuk TTD Digital" camunda:assignee="wd3">
      <incoming>sf_mitra_ya</incoming>
      <outgoing>sf_ajukan_ttd</outgoing>
    </userTask>
    <userTask id="task_ttd_pks" name="Review &#38; TTD Digital&#10;PKS" camunda:assignee="dekan">
      <incoming>sf_ajukan_ttd</incoming>
      <outgoing>sf_ttd_catat</outgoing>
    </userTask>
    <userTask id="task_catat_pks" name="Catat &#38; Kategorisasi&#10;PKS di Sistem Kerjasama" camunda:assignee="fitri">
      <incoming>sf_ttd_catat</incoming>
      <outgoing>sf_catat_dinas</outgoing>
    </userTask>
    <userTask id="task_dinas" name="Dinas Kunjungan&#10;ke Mitra (Dalam/LN)" camunda:assignee="wd3">
      <incoming>sf_catat_dinas</incoming>
      <outgoing>sf_dinas_susun</outgoing>
    </userTask>
    <userTask id="task_susun_ia" name="Identifikasi Kegiatan&#10;&#38; Susun Draft IA" camunda:assignee="wd3">
      <incoming>sf_dinas_susun</incoming>
      <incoming>sf_lanjutan_ya</incoming>
      <outgoing>sf_susun_link_ia</outgoing>
    </userTask>
    <serviceTask id="svc_kirim_draft_ia" name="Kirim Draft IA&#10;ke Mitra">
      <extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">http://217.217.254.115:8900/notify</camunda:inputParameter>
            <camunda:inputParameter name="method">POST</camunda:inputParameter>
            <camunda:inputParameter name="payload">{"recipient":"mitra","type":"ia_draft","processId":"${execution.processInstanceId}"}</camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">application/json</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </extensionElements>
      <incoming>sf_susun_link_ia</incoming>
      <outgoing>sf_link_ia_konfirmasi</outgoing>
    </serviceTask>
    <userTask id="task_konfirmasi_ia" name="Konfirmasi TTD&#10;Mitra terhadap IA" camunda:assignee="wd3">
      <incoming>sf_link_ia_konfirmasi</incoming>
      <outgoing>sf_konfirmasi_ajukan_ia</outgoing>
    </userTask>
    <userTask id="task_ajukan_ia_dekan" name="Ajukan IA ke Dekan&#10;untuk TTD Digital" camunda:assignee="wd3">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="adaKegiatanLanjutan" label="Apakah ada kegiatan lA lanjutan setelah ini?" type="boolean" defaultValue="false" />
        </camunda:formData>
      </extensionElements>
      <incoming>sf_konfirmasi_ajukan_ia</incoming>
      <outgoing>sf_ajukan_ia_ttd</outgoing>
    </userTask>
    <userTask id="task_ttd_ia" name="Review &#38; TTD Digital&#10;IA" camunda:assignee="dekan">
      <incoming>sf_ajukan_ia_ttd</incoming>
      <outgoing>sf_ttd_ia_catat</outgoing>
    </userTask>
    <userTask id="task_catat_ia" name="Catat IA di Sistem&#10;Kerjasama" camunda:assignee="fitri">
      <incoming>sf_ttd_ia_catat</incoming>
      <outgoing>sf_catat_ia_gw</outgoing>
    </userTask>
    <exclusiveGateway id="gw_lanjutan" name="Ada Kegiatan&#10;IA Lanjutan?">
      <incoming>sf_catat_ia_gw</incoming>
      <outgoing>sf_lanjutan_ya</outgoing>
      <outgoing>sf_lanjutan_tidak</outgoing>
    </exclusiveGateway>
    <endEvent id="end_1" name="PKS &#38; IA Aktif;&#10;Kerjasama Berjalan">
      <incoming>sf_lanjutan_tidak</incoming>
    </endEvent>
    <sequenceFlow id="sf_start_identifikasi" sourceRef="start_1" targetRef="task_identifikasi" />
    <sequenceFlow id="sf_identifikasi_inisiasi" sourceRef="task_identifikasi" targetRef="task_inisiasi" />
    <sequenceFlow id="sf_inisiasi_gw" sourceRef="task_inisiasi" targetRef="gw_tertarik" />
    <sequenceFlow id="sf_tertarik_tidak" name="Tidak" sourceRef="gw_tertarik" targetRef="end_ditolak">
      <conditionExpression xsi:type="tFormalExpression">${mitraTertarik == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_tertarik_ya" name="Ya" sourceRef="gw_tertarik" targetRef="task_diskusi">
      <conditionExpression xsi:type="tFormalExpression">${mitraTertarik == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_diskusi_link" sourceRef="task_diskusi" targetRef="svc_kirim_draft_pks" />
    <sequenceFlow id="sf_link_konfirmasi" sourceRef="svc_kirim_draft_pks" targetRef="task_konfirmasi_pks" />
    <sequenceFlow id="sf_konfirmasi_gw" sourceRef="task_konfirmasi_pks" targetRef="gw_mitra_pks" />
    <sequenceFlow id="sf_mitra_tidak" name="Tidak" sourceRef="gw_mitra_pks" targetRef="task_diskusi">
      <conditionExpression xsi:type="tFormalExpression">${mitraSetuju == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_mitra_ya" name="Ya" sourceRef="gw_mitra_pks" targetRef="task_ajukan_pks_dekan">
      <conditionExpression xsi:type="tFormalExpression">${mitraSetuju == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_ajukan_ttd" sourceRef="task_ajukan_pks_dekan" targetRef="task_ttd_pks" />
    <sequenceFlow id="sf_ttd_catat" sourceRef="task_ttd_pks" targetRef="task_catat_pks" />
    <sequenceFlow id="sf_catat_dinas" sourceRef="task_catat_pks" targetRef="task_dinas" />
    <sequenceFlow id="sf_dinas_susun" sourceRef="task_dinas" targetRef="task_susun_ia" />
    <sequenceFlow id="sf_susun_link_ia" sourceRef="task_susun_ia" targetRef="svc_kirim_draft_ia" />
    <sequenceFlow id="sf_link_ia_konfirmasi" sourceRef="svc_kirim_draft_ia" targetRef="task_konfirmasi_ia" />
    <sequenceFlow id="sf_konfirmasi_ajukan_ia" sourceRef="task_konfirmasi_ia" targetRef="task_ajukan_ia_dekan" />
    <sequenceFlow id="sf_ajukan_ia_ttd" sourceRef="task_ajukan_ia_dekan" targetRef="task_ttd_ia" />
    <sequenceFlow id="sf_ttd_ia_catat" sourceRef="task_ttd_ia" targetRef="task_catat_ia" />
    <sequenceFlow id="sf_catat_ia_gw" sourceRef="task_catat_ia" targetRef="gw_lanjutan" />
    <sequenceFlow id="sf_lanjutan_ya" name="Ya" sourceRef="gw_lanjutan" targetRef="task_susun_ia">
      <conditionExpression xsi:type="tFormalExpression">${adaKegiatanLanjutan == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_lanjutan_tidak" name="Tidak" sourceRef="gw_lanjutan" targetRef="end_1">
      <conditionExpression xsi:type="tFormalExpression">${adaKegiatanLanjutan == false}</conditionExpression>
    </sequenceFlow>
    <textAnnotation id="ann_ttd">
      <text>TTD digital menggantikan tanda tangan basah; Dekan dapat menandatangani dari mana saja via portal</text>
    </textAnnotation>
    <association id="assoc_ttd" sourceRef="task_ttd_pks" targetRef="ann_ttd" />
    <textAnnotation id="ann_draft">
      <text>Draft PKS/IA dikirim ke mitra via notification API; menggantikan pengiriman email informal</text>
    </textAnnotation>
    <association id="assoc_draft" sourceRef="svc_kirim_draft_pks" targetRef="ann_draft" />
    <textAnnotation id="ann_catat">
      <text>Pencatatan PKS &amp; IA di sistem terintegrasi; menggantikan Google Sheet manual Fitri</text>
    </textAnnotation>
    <association id="assoc_catat" sourceRef="task_catat_pks" targetRef="ann_catat" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="ProsesEToBe">
      <bpmndi:BPMNShape id="lane_wdiii_di" bpmnElement="lane_wdiii" isHorizontal="true">
