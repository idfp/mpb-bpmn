<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <process id="ProsesCAsIs" name="As-Is: Pengajuan Kegiatan Ormawa (KAK)" isExecutable="false">
    <laneSet id="laneSet_1">
      <lane id="lane_dekan" name="Dekan">
        <flowNodeRef>task_revisi_kak</flowNodeRef>
        <flowNodeRef>task_persetujuan_dekan</flowNodeRef>
        <flowNodeRef>gw_dekan_ok</flowNodeRef>
      </lane>
      <lane id="lane_wdiii" name="WD III (Wakil Dekan Kemahasiswaan)">
        <flowNodeRef>task_buat_spreadsheet</flowNodeRef>
        <flowNodeRef>task_validasi_kak</flowNodeRef>
        <flowNodeRef>task_ttd_lpj</flowNodeRef>
        <flowNodeRef>task_teruskan_keuangan_pusat</flowNodeRef>
        <flowNodeRef>gw_wdiii_ok</flowNodeRef>
        <flowNodeRef>endEvent_1</flowNodeRef>
      </lane>
      <lane id="lane_suryadi" name="Mas Suryadi (Keuangan)">
        <flowNodeRef>task_verifikasi_anggaran</flowNodeRef>
        <flowNodeRef>task_verifikasi_kuitansi</flowNodeRef>
        <flowNodeRef>gw_anggaran_ok</flowNodeRef>
        <flowNodeRef>gw_kuitansi_ok</flowNodeRef>
      </lane>
      <lane id="lane_fitri" name="Mbak Fitri (Staf Administrasi)">
        <flowNodeRef>task_teruskan_keuangan</flowNodeRef>
        <flowNodeRef>task_periksa_format</flowNodeRef>
        <flowNodeRef>task_terima_lpj</flowNodeRef>
        <flowNodeRef>task_minta_ttd_wdiii</flowNodeRef>
        <flowNodeRef>msg_catch_kak</flowNodeRef>
        <flowNodeRef>gw_format_ok</flowNodeRef>
        <flowNodeRef>msg_catch_lpj</flowNodeRef>
      </lane>
      <lane id="lane_ormawa" name="Ormawa / UKM">
        <flowNodeRef>task_paparkan_proker</flowNodeRef>
        <flowNodeRef>task_ajukan_kak</flowNodeRef>
        <flowNodeRef>task_laksanakan_kegiatan</flowNodeRef>
        <flowNodeRef>task_terlambat_lpj</flowNodeRef>
        <flowNodeRef>task_buat_lpj</flowNodeRef>
        <flowNodeRef>startEvent_1</flowNodeRef>
        <flowNodeRef>msg_throw_kak</flowNodeRef>
        <flowNodeRef>boundary_timer_lpj</flowNodeRef>
        <flowNodeRef>msg_throw_lpj</flowNodeRef>
      </lane>
    </laneSet>
    <dataStoreReference id="ds_spreadsheet" name="Google Spreadsheet&#10;Monitoring Proker" />
    <dataStoreReference id="ds_sheet_kerjasama" name="Google Sheet&#10;Arsip Dokumen Fitri" />
    <startEvent id="startEvent_1" name="Awal Tahun:&#10;Perencanaan Proker">
      <outgoing>sf_start_paparkan</outgoing>
    </startEvent>
    <task id="task_paparkan_proker" name="Paparkan Program Kerja&#10;Tahunan ke WD III">
      <incoming>sf_start_paparkan</incoming>
      <outgoing>sf_paparkan_wdiii</outgoing>
      <property id="prop_1" name="__targetRef_placeholder" />
      <dataInputAssociation id="dia_1">
        <sourceRef>prop_1</sourceRef>
        <targetRef>ds_spreadsheet</targetRef>
      </dataInputAssociation>
    </task>
    <task id="task_buat_spreadsheet" name="Catat Program Kerja di&#10;Google Spreadsheet Monitoring">
      <incoming>sf_paparkan_wdiii</incoming>
      <outgoing>sf_spreadsheet_done</outgoing>
      <dataOutputAssociation id="doa_spreadsheet">
        <targetRef>ds_spreadsheet</targetRef>
      </dataOutputAssociation>
    </task>
    <task id="task_ajukan_kak" name="Siapkan &#38; Lengkapi&#10;KAK (Hard Copy)">
      <incoming>sf_spreadsheet_done</incoming>
      <incoming>sf_revisi_kembali</incoming>
      <outgoing>sf_kak_msg_throw</outgoing>
    </task>
    <intermediateThrowEvent id="msg_throw_kak" name="Kirim KAK&#10;ke Ibu Fitri">
      <incoming>sf_kak_msg_throw</incoming>
      <outgoing>sf_msg_throw_kak_out</outgoing>
      <messageEventDefinition id="med_throw_kak" />
    </intermediateThrowEvent>
    <dataObjectReference id="do_kak" name="KAK&#10;(Hard Copy)" dataObjectRef="dao_kak" />
    <dataObject id="dao_kak" />
    <intermediateCatchEvent id="msg_catch_kak" name="Terima KAK&#10;dari Ormawa">
      <incoming>sf_msg_throw_kak_out</incoming>
      <outgoing>sf_catch_kak_periksa</outgoing>
      <messageEventDefinition id="med_catch_kak" />
    </intermediateCatchEvent>
    <task id="task_periksa_format" name="Periksa Format KAK&#10;&#38; Kelengkapan TTD">
      <incoming>sf_catch_kak_periksa</incoming>
      <outgoing>sf_periksa_gw</outgoing>
      <dataOutputAssociation id="doa_kak_fitri">
        <targetRef>ds_sheet_kerjasama</targetRef>
      </dataOutputAssociation>
    </task>
    <exclusiveGateway id="gw_format_ok" name="Format&#10;Lengkap?">
      <incoming>sf_periksa_gw</incoming>
      <outgoing>sf_format_ok</outgoing>
      <outgoing>sf_format_revisi</outgoing>
    </exclusiveGateway>
    <task id="task_teruskan_keuangan" name="Teruskan KAK ke&#10;Bagian Keuangan">
      <incoming>sf_format_ok</incoming>
      <outgoing>sf_ke_suryadi</outgoing>
    </task>
    <task id="task_verifikasi_anggaran" name="Verifikasi Anggaran&#10;vs SBM Kemendikbud">
      <incoming>sf_ke_suryadi</incoming>
      <outgoing>sf_anggaran_gw</outgoing>
    </task>
    <exclusiveGateway id="gw_anggaran_ok" name="Anggaran&#10;Sesuai SBM?">
      <incoming>sf_anggaran_gw</incoming>
      <outgoing>sf_anggaran_ok</outgoing>
      <outgoing>sf_anggaran_revisi</outgoing>
    </exclusiveGateway>
    <task id="task_validasi_kak" name="Validasi KAK&#10;(Konten &#38; Kelayakan IKU)">
      <incoming>sf_anggaran_ok</incoming>
      <outgoing>sf_wdiii_gw</outgoing>
    </task>
    <exclusiveGateway id="gw_wdiii_ok" name="WD III&#10;Setuju?">
      <incoming>sf_wdiii_gw</incoming>
      <outgoing>sf_wdiii_ok</outgoing>
      <outgoing>sf_wdiii_revisi</outgoing>
    </exclusiveGateway>
    <task id="task_persetujuan_dekan" name="Review &#38; Persetujuan&#10;KAK">
      <incoming>sf_wdiii_ok</incoming>
      <outgoing>Flow_0osvcn7</outgoing>
    </task>
    <exclusiveGateway id="gw_dekan_ok" name="Dekan&#10;Setuju?">
      <incoming>Flow_0osvcn7</incoming>
      <outgoing>sf_dekan_ok</outgoing>
      <outgoing>sf_dekan_revisi</outgoing>
    </exclusiveGateway>
    <task id="task_revisi_kak" name="Revisi KAK sesuai&#10;Catatan">
      <incoming>sf_format_revisi</incoming>
      <incoming>sf_anggaran_revisi</incoming>
      <incoming>sf_wdiii_revisi</incoming>
      <incoming>sf_dekan_revisi</incoming>
      <outgoing>sf_revisi_kembali</outgoing>
    </task>
    <task id="task_laksanakan_kegiatan" name="Laksanakan Kegiatan">
      <incoming>sf_dekan_ok</incoming>
      <outgoing>sf_laksana_lpj</outgoing>
      <outgoing>sf_timer_terlambat</outgoing>
    </task>
    <boundaryEvent id="boundary_timer_lpj" name="2 Minggu&#10;Berlalu" cancelActivity="false" attachedToRef="task_laksanakan_kegiatan">
      <timerEventDefinition id="ted_lpj">
        <timeDuration xsi:type="tFormalExpression">P14D</timeDuration>
      </timerEventDefinition>
    </boundaryEvent>
    <task id="task_terlambat_lpj" name="Ingatkan Ormawa via WA&#10;(LPJ Terlambat)">
      <incoming>sf_timer_terlambat</incoming>
      <outgoing>sf_terlambat_buat_lpj</outgoing>
    </task>
    <task id="task_buat_lpj" name="Buat LPJ&#10;(Hard Copy)">
      <incoming>sf_laksana_lpj</incoming>
      <incoming>sf_terlambat_buat_lpj</incoming>
      <incoming>sf_kuitansi_revisi</incoming>
      <outgoing>sf_lpj_msg_throw</outgoing>
    </task>
    <dataObjectReference id="do_lpj" name="LPJ + Kuitansi&#10;(Hard Copy)" dataObjectRef="dao_lpj" />
    <dataObject id="dao_lpj" />
    <intermediateThrowEvent id="msg_throw_lpj" name="Serahkan LPJ&#10;ke Fitri">
      <incoming>sf_lpj_msg_throw</incoming>
      <outgoing>sf_msg_throw_lpj_out</outgoing>
      <messageEventDefinition id="med_throw_lpj" />
    </intermediateThrowEvent>
    <intermediateCatchEvent id="msg_catch_lpj" name="Terima LPJ&#10;dari Ormawa">
      <incoming>sf_msg_throw_lpj_out</incoming>
      <outgoing>sf_catch_lpj_terima</outgoing>
      <messageEventDefinition id="med_catch_lpj" />
    </intermediateCatchEvent>
    <task id="task_terima_lpj" name="Teruskan LPJ ke&#10;Bagian Keuangan">
      <incoming>sf_catch_lpj_terima</incoming>
      <outgoing>sf_lpj_ke_suryadi</outgoing>
    </task>
    <task id="task_verifikasi_kuitansi" name="Verifikasi Kuitansi&#10;&#38; Bukti Pengeluaran">
      <incoming>sf_lpj_ke_suryadi</incoming>
      <outgoing>sf_kuitansi_gw</outgoing>
    </task>
    <exclusiveGateway id="gw_kuitansi_ok" name="Kuitansi&#10;Lengkap &#38; Sah?">
      <incoming>sf_kuitansi_gw</incoming>
      <outgoing>sf_kuitansi_ok</outgoing>
      <outgoing>sf_kuitansi_revisi</outgoing>
    </exclusiveGateway>
    <task id="task_minta_ttd_wdiii" name="Ajukan LPJ untuk&#10;TTD WD III">
      <incoming>sf_kuitansi_ok</incoming>
      <outgoing>sf_minta_ttd</outgoing>
    </task>
    <task id="task_ttd_lpj" name="Tanda Tangan LPJ&#10;(Pengesahan Kegiatan Selesai)">
      <incoming>sf_minta_ttd</incoming>
      <outgoing>sf_ttd_pusat</outgoing>
      <dataOutputAssociation id="doa_lpj_wdiii">
        <targetRef>ds_spreadsheet</targetRef>
      </dataOutputAssociation>
    </task>
    <task id="task_teruskan_keuangan_pusat" name="Laporkan LPJ ke&#10;Keuangan Pusat">
      <incoming>sf_ttd_pusat</incoming>
      <outgoing>sf_pusat_end</outgoing>
    </task>
    <endEvent id="endEvent_1" name="Selesai: Dana Dicairkan&#10;&#38; Kegiatan Terdokumentasi">
      <incoming>sf_pusat_end</incoming>
    </endEvent>
    <sequenceFlow id="sf_start_paparkan" sourceRef="startEvent_1" targetRef="task_paparkan_proker" />
    <sequenceFlow id="sf_paparkan_wdiii" sourceRef="task_paparkan_proker" targetRef="task_buat_spreadsheet" />
    <sequenceFlow id="sf_spreadsheet_done" sourceRef="task_buat_spreadsheet" targetRef="task_ajukan_kak" />
    <sequenceFlow id="sf_kak_msg_throw" sourceRef="task_ajukan_kak" targetRef="msg_throw_kak" />
    <sequenceFlow id="sf_msg_throw_kak_out" sourceRef="msg_throw_kak" targetRef="msg_catch_kak" />
    <sequenceFlow id="sf_catch_kak_periksa" sourceRef="msg_catch_kak" targetRef="task_periksa_format" />
    <sequenceFlow id="sf_periksa_gw" sourceRef="task_periksa_format" targetRef="gw_format_ok" />
    <sequenceFlow id="sf_format_ok" name="yes" sourceRef="gw_format_ok" targetRef="task_teruskan_keuangan">
      <conditionExpression>Format lengkap</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_format_revisi" name="no" sourceRef="gw_format_ok" targetRef="task_revisi_kak">
      <conditionExpression>Format tidak lengkap / perlu revisi</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_ke_suryadi" sourceRef="task_teruskan_keuangan" targetRef="task_verifikasi_anggaran" />
    <sequenceFlow id="sf_anggaran_gw" sourceRef="task_verifikasi_anggaran" targetRef="gw_anggaran_ok" />
    <sequenceFlow id="sf_anggaran_ok" name="yes" sourceRef="gw_anggaran_ok" targetRef="task_validasi_kak">
      <conditionExpression>Anggaran sesuai SBM</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_anggaran_revisi" name="no" sourceRef="gw_anggaran_ok" targetRef="task_revisi_kak">
      <conditionExpression>Anggaran tidak sesuai SBM</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_wdiii_gw" sourceRef="task_validasi_kak" targetRef="gw_wdiii_ok" />
    <sequenceFlow id="sf_wdiii_ok" name="yes" sourceRef="gw_wdiii_ok" targetRef="task_persetujuan_dekan">
      <conditionExpression>Disetujui WD III</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_wdiii_revisi" name="no" sourceRef="gw_wdiii_ok" targetRef="task_revisi_kak">
      <conditionExpression>Perlu revisi</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_dekan_ok" name="yes" sourceRef="gw_dekan_ok" targetRef="task_laksanakan_kegiatan">
      <conditionExpression>Disetujui Dekan</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_dekan_revisi" name="no" sourceRef="gw_dekan_ok" targetRef="task_revisi_kak">
      <conditionExpression>Perlu revisi</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_revisi_kembali" sourceRef="task_revisi_kak" targetRef="task_ajukan_kak" />
    <sequenceFlow id="sf_laksana_lpj" sourceRef="task_laksanakan_kegiatan" targetRef="task_buat_lpj" />
    <sequenceFlow id="sf_timer_terlambat" sourceRef="task_laksanakan_kegiatan" targetRef="task_terlambat_lpj" />
    <sequenceFlow id="sf_terlambat_buat_lpj" sourceRef="task_terlambat_lpj" targetRef="task_buat_lpj" />
    <sequenceFlow id="sf_lpj_msg_throw" sourceRef="task_buat_lpj" targetRef="msg_throw_lpj" />
    <sequenceFlow id="sf_msg_throw_lpj_out" sourceRef="msg_throw_lpj" targetRef="msg_catch_lpj" />
    <sequenceFlow id="sf_catch_lpj_terima" sourceRef="msg_catch_lpj" targetRef="task_terima_lpj" />
    <sequenceFlow id="sf_lpj_ke_suryadi" sourceRef="task_terima_lpj" targetRef="task_verifikasi_kuitansi" />
    <sequenceFlow id="sf_kuitansi_gw" sourceRef="task_verifikasi_kuitansi" targetRef="gw_kuitansi_ok" />
    <sequenceFlow id="sf_kuitansi_ok" name="yes" sourceRef="gw_kuitansi_ok" targetRef="task_minta_ttd_wdiii">
      <conditionExpression>Kuitansi lengkap dan sah</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_kuitansi_revisi" name="no" sourceRef="gw_kuitansi_ok" targetRef="task_buat_lpj">
      <conditionExpression>Kuitansi tidak lengkap / perlu revisi</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_minta_ttd" sourceRef="task_minta_ttd_wdiii" targetRef="task_ttd_lpj" />
    <sequenceFlow id="sf_ttd_pusat" sourceRef="task_ttd_lpj" targetRef="task_teruskan_keuangan_pusat" />
    <sequenceFlow id="sf_pusat_end" sourceRef="task_teruskan_keuangan_pusat" targetRef="endEvent_1" />
    <sequenceFlow id="Flow_0osvcn7" sourceRef="task_persetujuan_dekan" targetRef="gw_dekan_ok" />
    <textAnnotation id="ann_hardcopy">
      <text>Dokumen hard copy, belum ada sistem digital pengajuan</text>
    </textAnnotation>
    <association id="assoc_hardcopy" sourceRef="task_ajukan_kak" targetRef="ann_hardcopy" />
    <textAnnotation id="ann_sbm">
      <text>SBM = Standar Biaya Minimum Kemendikbud; termasuk uang transport, penginapan, bahan habis pakai. Hadiah harus barang, bukan uang.</text>
    </textAnnotation>
    <association id="assoc_sbm" sourceRef="task_verifikasi_anggaran" targetRef="ann_sbm" />
    <textAnnotation id="ann_iku">
      <text>Kegiatan yang outputnya tidak mendukung IKU dapat ditolak oleh pimpinan</text>
    </textAnnotation>
    <association id="assoc_iku" sourceRef="task_validasi_kak" targetRef="ann_iku" />
    <textAnnotation id="ann_revisi">
      <text>Revisi dapat datang dari 4 titik: Fitri (format), Suryadi (anggaran), WD III (konten/IKU), atau Dekan. Tidak ada batas jumlah iterasi revisi.</text>
    </textAnnotation>
    <association id="assoc_revisi" sourceRef="task_revisi_kak" targetRef="ann_revisi" />
    <textAnnotation id="ann_timer">
      <text>LPJ wajib dikumpulkan maks. 2 minggu pasca kegiatan. Dalam praktik sering terlambat hingga mendekati tutup buku.</text>
    </textAnnotation>
    <association id="assoc_timer" sourceRef="task_laksanakan_kegiatan" targetRef="ann_timer" />
    <textAnnotation id="ann_lpj_hardcopy">
      <text>LPJ beserta kuitansi dan bukti pengeluaran diserahkan dalam bentuk hard copy</text>
    </textAnnotation>
    <association id="assoc_lpj_hardcopy" sourceRef="task_buat_lpj" targetRef="ann_lpj_hardcopy" />
    <textAnnotation id="ann_update_spreadsheet">
      <text>Status program kerja di Google Spreadsheet diupdate: "sudah terlaksana" dan realisasi dana dicatat</text>
    </textAnnotation>
    <association id="assoc_update_spreadsheet" sourceRef="task_ttd_lpj" targetRef="ann_update_spreadsheet" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="ProsesCAsIs">
      <bpmndi:BPMNShape id="lane_ormawa_di" bpmnElement="lane_ormawa" isHorizontal="true">
        <dc:Bounds x="160" y="160" width="2190" height="170" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_fitri_di" bpmnElement="lane_fitri" isHorizontal="true">
        <dc:Bounds x="160" y="330" width="2190" height="170" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_suryadi_di" bpmnElement="lane_suryadi" isHorizontal="true">
        <dc:Bounds x="160" y="500" width="2190" height="170" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_wdiii_di" bpmnElement="lane_wdiii" isHorizontal="true">
        <dc:Bounds x="160" y="670" width="2190" height="170" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_dekan_di" bpmnElement="lane_dekan" isHorizontal="true">
        <dc:Bounds x="160" y="840" width="2190" height="170" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ds_spreadsheet_di" bpmnElement="ds_spreadsheet" isDataStoreReference="true">
        <dc:Bounds x="235" y="710" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="219" y="768" width="87" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ds_sheet_kerjasama_di" bpmnElement="ds_sheet_kerjasama" isDataStoreReference="true">
        <dc:Bounds x="235" y="390" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="224" y="448" width="76" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="startEvent_1_di" bpmnElement="startEvent_1">
        <dc:Bounds x="242" y="227" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="227" y="270" width="66" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_paparkan_proker_di" bpmnElement="task_paparkan_proker">
        <dc:Bounds x="320" y="205" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_buat_spreadsheet_di" bpmnElement="task_buat_spreadsheet">
        <dc:Bounds x="320" y="705" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_ajukan_kak_di" bpmnElement="task_ajukan_kak">
        <dc:Bounds x="490" y="205" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="msg_throw_kak_di" bpmnElement="msg_throw_kak">
        <dc:Bounds x="662" y="227" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="654" y="190" width="52" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="do_kak_di" bpmnElement="do_kak" isDataObject="true">
        <dc:Bounds x="502" y="515" width="36" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="491" y="572" width="60" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="msg_catch_kak_di" bpmnElement="msg_catch_kak">
        <dc:Bounds x="662" y="397" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="650" y="440" width="63" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_periksa_format_di" bpmnElement="task_periksa_format">
        <dc:Bounds x="770" y="375" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_format_ok_di" bpmnElement="gw_format_ok" isMarkerVisible="true">
        <dc:Bounds x="905" y="390" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="905" y="352.5" width="49" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_teruskan_keuangan_di" bpmnElement="task_teruskan_keuangan">
        <dc:Bounds x="1000" y="375" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_verifikasi_anggaran_di" bpmnElement="task_verifikasi_anggaran">
        <dc:Bounds x="1000" y="540" width="120" height="80" />
      </bpmndi:BPMNShape>
