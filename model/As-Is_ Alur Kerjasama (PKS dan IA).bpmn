<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <process id="ProsesEAsIs" name="As-Is: Alur Kerjasama (PKS dan IA)" isExecutable="false">
    <laneSet id="ls1">
      <lane id="lane_mitra" name="Mitra Kerjasama">
        <flowNodeRef>task_review_draft</flowNodeRef>
        <flowNodeRef>task_ttd_pks_mitra</flowNodeRef>
        <flowNodeRef>task_ttd_ia_mitra</flowNodeRef>
        <flowNodeRef>msg_catch_draft</flowNodeRef>
        <flowNodeRef>gw_mitra_setuju</flowNodeRef>
        <flowNodeRef>msg_throw_pks</flowNodeRef>
        <flowNodeRef>msg_throw_ia</flowNodeRef>
      </lane>
      <lane id="lane_dekan" name="Dekan">
        <flowNodeRef>task_review_ttd_pks</flowNodeRef>
        <flowNodeRef>task_review_ttd_ia</flowNodeRef>
      </lane>
      <lane id="lane_fitri" name="Mbak Fitri (Staf Administrasi)">
        <flowNodeRef>task_catat_pks</flowNodeRef>
        <flowNodeRef>task_catat_ia</flowNodeRef>
      </lane>
      <lane id="lane_wdiii" name="WD III (Wakil Dekan Kemahasiswaan)">
        <flowNodeRef>task_identifikasi_mitra</flowNodeRef>
        <flowNodeRef>task_inisiasi_kontak</flowNodeRef>
        <flowNodeRef>task_diskusi_ruang_lingkup</flowNodeRef>
        <flowNodeRef>task_susun_draft_pks</flowNodeRef>
        <flowNodeRef>task_ajukan_pks_dekan</flowNodeRef>
        <flowNodeRef>task_dinas_kunjungan</flowNodeRef>
        <flowNodeRef>task_identifikasi_kegiatan</flowNodeRef>
        <flowNodeRef>task_susun_ia</flowNodeRef>
        <flowNodeRef>task_ajukan_ia_dekan</flowNodeRef>
        <flowNodeRef>start_1</flowNodeRef>
        <flowNodeRef>gw_mitra_tertarik</flowNodeRef>
        <flowNodeRef>msg_throw_draft</flowNodeRef>
        <flowNodeRef>end_1</flowNodeRef>
        <flowNodeRef>gw_ada_kegiatan_lanjut</flowNodeRef>
        <flowNodeRef>Event_1e8t2w9</flowNodeRef>
      </lane>
    </laneSet>
    <dataStoreReference id="ds_gsheet" name="Google Sheet Kerjasama&#10;(PKS &#38; IA - Mbak Fitri)" />
    <startEvent id="start_1" name="Identifikasi Kebutuhan&#10;Kerjasama Baru">
      <outgoing>sf_start_identifikasi</outgoing>
    </startEvent>
    <task id="task_identifikasi_mitra" name="Identifikasi &#38; Seleksi&#10;Calon Mitra Kerjasama">
      <incoming>sf_start_identifikasi</incoming>
      <outgoing>sf_identifikasi_inisiasi</outgoing>
    </task>
    <task id="task_inisiasi_kontak" name="Inisiasi Kontak dengan&#10;Calon Mitra">
      <incoming>sf_identifikasi_inisiasi</incoming>
      <outgoing>sf_inisiasi_gw</outgoing>
    </task>
    <exclusiveGateway id="gw_mitra_tertarik" name="Mitra&#10;Tertarik?">
      <incoming>sf_inisiasi_gw</incoming>
      <outgoing>sf_tertarik_diskusi</outgoing>
      <outgoing>sf_tidak_tertarik_end</outgoing>
    </exclusiveGateway>
    <task id="task_diskusi_ruang_lingkup" name="Diskusi Ruang Lingkup&#10;Kerjasama dengan Mitra">
      <incoming>sf_tertarik_diskusi</incoming>
      <outgoing>sf_diskusi_draft</outgoing>
    </task>
    <task id="task_susun_draft_pks" name="Susun Draft PKS&#10;(Perjanjian Kerjasama)">
      <incoming>sf_diskusi_draft</incoming>
      <outgoing>sf_draft_throw</outgoing>
    </task>
    <dataObjectReference id="do_draft_pks" name="Draft PKS&#10;(Dokumen)" dataObjectRef="dao_draft_pks" />
    <dataObject id="dao_draft_pks" />
    <intermediateThrowEvent id="msg_throw_draft" name="Kirim Draft PKS&#10;ke Mitra">
      <incoming>sf_draft_throw</incoming>
      <outgoing>sf_throw_catch_draft</outgoing>
      <messageEventDefinition id="med_throw_draft" />
    </intermediateThrowEvent>
    <intermediateCatchEvent id="msg_catch_draft" name="Terima Draft PKS&#10;dari WD III">
      <incoming>sf_throw_catch_draft</incoming>
      <outgoing>sf_catch_review</outgoing>
      <messageEventDefinition id="med_catch_draft" />
    </intermediateCatchEvent>
    <task id="task_review_draft" name="Review Draft PKS">
      <incoming>sf_catch_review</incoming>
      <outgoing>sf_review_gw</outgoing>
    </task>
    <exclusiveGateway id="gw_mitra_setuju" name="Mitra&#10;Setuju Draft?">
      <incoming>sf_review_gw</incoming>
      <outgoing>sf_setuju_ttd_mitra</outgoing>
      <outgoing>sf_revisi_draft</outgoing>
    </exclusiveGateway>
    <task id="task_ttd_pks_mitra" name="Tanda Tangan PKS&#10;(Mitra)">
      <incoming>sf_setuju_ttd_mitra</incoming>
      <outgoing>sf_ttd_mitra_throw</outgoing>
    </task>
    <intermediateThrowEvent id="msg_throw_pks" name="Kirim PKS&#10;ke WD III/Dekan">
      <incoming>sf_ttd_mitra_throw</incoming>
      <outgoing>sf_throw_pks_dekan</outgoing>
      <messageEventDefinition id="med_throw_pks" />
    </intermediateThrowEvent>
    <task id="task_ajukan_pks_dekan" name="Ajukan PKS ke Dekan&#10;untuk Persetujuan &#38; TTD">
      <incoming>Flow_1r2weps</incoming>
      <outgoing>sf_ajukan_review_dekan</outgoing>
    </task>
    <task id="task_review_ttd_pks" name="Review &#38; Tanda Tangan&#10;PKS (Tanda Tangan Basah)">
      <incoming>sf_ajukan_review_dekan</incoming>
      <outgoing>sf_ttd_dekan_catat</outgoing>
    </task>
    <task id="task_catat_pks" name="Catat PKS di Google Sheet&#10;Kerjasama per Kategori">
      <incoming>sf_ttd_dekan_catat</incoming>
      <outgoing>sf_catat_pks_dinas</outgoing>
      <dataOutputAssociation id="doa_pks">
        <targetRef>ds_gsheet</targetRef>
      </dataOutputAssociation>
    </task>
    <task id="task_dinas_kunjungan" name="Dinas Kunjungan ke Mitra&#10;(Dalam / Luar Negeri)">
      <incoming>sf_catat_pks_dinas</incoming>
      <outgoing>sf_dinas_identifikasi</outgoing>
    </task>
    <task id="task_identifikasi_kegiatan" name="Identifikasi Kegiatan Spesifik&#10;yang Akan Dilakukan Bersama Mitra">
      <incoming>sf_dinas_identifikasi</incoming>
      <outgoing>sf_identifikasi_ia</outgoing>
    </task>
    <task id="task_susun_ia" name="Susun Draft IA&#10;(Implementing Agreement)">
      <incoming>sf_identifikasi_ia</incoming>
      <outgoing>sf_ia_ttd_mitra</outgoing>
    </task>
    <dataObjectReference id="do_ia" name="IA&#10;(Implementing Agreement)" dataObjectRef="dao_ia" />
    <dataObject id="dao_ia" />
    <task id="task_ttd_ia_mitra" name="Tanda Tangan IA&#10;(Mitra)">
      <incoming>sf_ia_ttd_mitra</incoming>
      <outgoing>sf_ttd_ia_mitra_throw</outgoing>
    </task>
    <intermediateThrowEvent id="msg_throw_ia" name="Kirim IA ke&#10;WD III/Dekan">
      <incoming>sf_ttd_ia_mitra_throw</incoming>
      <outgoing>sf_throw_ia_ajukan</outgoing>
      <messageEventDefinition id="med_throw_ia" />
    </intermediateThrowEvent>
    <task id="task_ajukan_ia_dekan" name="Ajukan IA ke Dekan&#10;untuk Tanda Tangan">
      <incoming>sf_throw_ia_ajukan</incoming>
      <outgoing>sf_ajukan_ia_review</outgoing>
    </task>
    <task id="task_review_ttd_ia" name="Review &#38; Tanda Tangan&#10;IA (Tanda Tangan Basah)">
      <incoming>sf_ajukan_ia_review</incoming>
      <outgoing>sf_ttd_ia_catat</outgoing>
    </task>
    <task id="task_catat_ia" name="Catat IA di Google Sheet&#10;Kerjasama">
      <incoming>sf_ttd_ia_catat</incoming>
      <outgoing>sf_catat_ia_gw</outgoing>
      <dataOutputAssociation id="doa_ia">
        <targetRef>ds_gsheet</targetRef>
      </dataOutputAssociation>
    </task>
    <exclusiveGateway id="gw_ada_kegiatan_lanjut" name="Ada Kegiatan&#10;IA Lanjutan?">
      <incoming>sf_catat_ia_gw</incoming>
      <outgoing>sf_ada_kegiatan</outgoing>
      <outgoing>sf_tidak_ada_end</outgoing>
    </exclusiveGateway>
    <endEvent id="end_1" name="PKS &#38; IA Aktif;&#10;Kerjasama Berjalan">
      <incoming>sf_tidak_tertarik_end</incoming>
      <incoming>sf_tidak_ada_end</incoming>
    </endEvent>
    <sequenceFlow id="sf_start_identifikasi" sourceRef="start_1" targetRef="task_identifikasi_mitra" />
    <sequenceFlow id="sf_identifikasi_inisiasi" sourceRef="task_identifikasi_mitra" targetRef="task_inisiasi_kontak" />
    <sequenceFlow id="sf_inisiasi_gw" sourceRef="task_inisiasi_kontak" targetRef="gw_mitra_tertarik" />
    <sequenceFlow id="sf_tertarik_diskusi" name="Ya" sourceRef="gw_mitra_tertarik" targetRef="task_diskusi_ruang_lingkup">
      <conditionExpression>Mitra tertarik</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_tidak_tertarik_end" sourceRef="gw_mitra_tertarik" targetRef="end_1">
      <conditionExpression>Mitra tidak tertarik</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_diskusi_draft" sourceRef="task_diskusi_ruang_lingkup" targetRef="task_susun_draft_pks" />
    <sequenceFlow id="sf_draft_throw" sourceRef="task_susun_draft_pks" targetRef="msg_throw_draft" />
    <sequenceFlow id="sf_throw_catch_draft" sourceRef="msg_throw_draft" targetRef="msg_catch_draft" />
    <sequenceFlow id="sf_catch_review" sourceRef="msg_catch_draft" targetRef="task_review_draft" />
    <sequenceFlow id="sf_review_gw" sourceRef="task_review_draft" targetRef="gw_mitra_setuju" />
    <sequenceFlow id="sf_setuju_ttd_mitra" sourceRef="gw_mitra_setuju" targetRef="task_ttd_pks_mitra">
      <conditionExpression>Setuju</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_revisi_draft" sourceRef="gw_mitra_setuju" targetRef="task_susun_draft_pks">
      <conditionExpression>Perlu revisi</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_ttd_mitra_throw" sourceRef="task_ttd_pks_mitra" targetRef="msg_throw_pks" />
    <sequenceFlow id="sf_throw_pks_dekan" sourceRef="msg_throw_pks" targetRef="Event_1e8t2w9" />
    <sequenceFlow id="sf_ajukan_review_dekan" sourceRef="task_ajukan_pks_dekan" targetRef="task_review_ttd_pks" />
    <sequenceFlow id="sf_ttd_dekan_catat" sourceRef="task_review_ttd_pks" targetRef="task_catat_pks" />
    <sequenceFlow id="sf_catat_pks_dinas" sourceRef="task_catat_pks" targetRef="task_dinas_kunjungan" />
    <sequenceFlow id="sf_dinas_identifikasi" sourceRef="task_dinas_kunjungan" targetRef="task_identifikasi_kegiatan" />
    <sequenceFlow id="sf_identifikasi_ia" sourceRef="task_identifikasi_kegiatan" targetRef="task_susun_ia" />
    <sequenceFlow id="sf_ia_ttd_mitra" sourceRef="task_susun_ia" targetRef="task_ttd_ia_mitra" />
    <sequenceFlow id="sf_ttd_ia_mitra_throw" sourceRef="task_ttd_ia_mitra" targetRef="msg_throw_ia" />
    <sequenceFlow id="sf_throw_ia_ajukan" sourceRef="msg_throw_ia" targetRef="task_ajukan_ia_dekan" />
    <sequenceFlow id="sf_ajukan_ia_review" sourceRef="task_ajukan_ia_dekan" targetRef="task_review_ttd_ia" />
    <sequenceFlow id="sf_ttd_ia_catat" sourceRef="task_review_ttd_ia" targetRef="task_catat_ia" />
    <sequenceFlow id="sf_catat_ia_gw" sourceRef="task_catat_ia" targetRef="gw_ada_kegiatan_lanjut" />
    <sequenceFlow id="sf_ada_kegiatan" sourceRef="gw_ada_kegiatan_lanjut" targetRef="task_identifikasi_kegiatan">
      <conditionExpression>Ada kegiatan IA lanjutan</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_tidak_ada_end" sourceRef="gw_ada_kegiatan_lanjut" targetRef="end_1">
      <conditionExpression>Tidak ada kegiatan lanjutan</conditionExpression>
    </sequenceFlow>
    <intermediateCatchEvent id="Event_1e8t2w9" name="Terima PKS dari Mitra">
      <incoming>sf_throw_pks_dekan</incoming>
      <outgoing>Flow_1r2weps</outgoing>
      <messageEventDefinition id="MessageEventDefinition_1rcwqu7" />
    </intermediateCatchEvent>
    <sequenceFlow id="Flow_1r2weps" sourceRef="Event_1e8t2w9" targetRef="task_ajukan_pks_dekan" />
    <textAnnotation id="ann_kriteria">
      <text>Mitra harus memenuhi kriteria: BUMN, multinasional, atau startup. Banyak mitra industri lebih berorientasi menjual produk daripada berkolaborasi.</text>
    </textAnnotation>
    <association id="assoc_kriteria" sourceRef="task_identifikasi_mitra" targetRef="ann_kriteria" />
    <textAnnotation id="ann_ttd">
      <text>Tanda tangan basah; Dekan harus hadir fisik. PKS berlaku untuk jangka waktu tertentu dan bisa menghasilkan multiple IA.</text>
    </textAnnotation>
    <association id="assoc_ttd" sourceRef="task_review_ttd_pks" targetRef="ann_ttd" />
    <textAnnotation id="ann_catat">
      <text>Dikategorikan: pendidikan / penelitian / pengabdian; dalam negeri / luar negeri. Disertai grafik dan rekap status aktif/tidak.</text>
    </textAnnotation>
    <association id="assoc_catat" sourceRef="task_catat_pks" targetRef="ann_catat" />
    <textAnnotation id="ann_dinas">
      <text>Kunjungan dalam negeri sudah beberapa kali; kunjungan luar negeri baru ke Malaysia. Termasuk dalam kategori tugas kedinasan.</text>
    </textAnnotation>
    <association id="assoc_dinas" sourceRef="task_dinas_kunjungan" targetRef="ann_dinas" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_E">
    <bpmndi:BPMNPlane id="BPMNPlane_E" bpmnElement="ProsesEAsIs">
      <bpmndi:BPMNShape id="lane_wdiii_di" bpmnElement="lane_wdiii" isHorizontal="true">
