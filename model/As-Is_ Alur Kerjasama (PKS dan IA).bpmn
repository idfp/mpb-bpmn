        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_ajukan_ia_dekan_di" bpmnElement="task_ajukan_ia_dekan">
        <dc:Bounds x="2100" y="239" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_review_ttd_ia_di" bpmnElement="task_review_ttd_ia">
        <dc:Bounds x="2100" y="535" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_catat_ia_di" bpmnElement="task_catat_ia">
        <dc:Bounds x="2100" y="400" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_ada_kegiatan_lanjut_di" bpmnElement="gw_ada_kegiatan_lanjut" isMarkerVisible="true">
        <dc:Bounds x="2245" y="254" width="50" height="50" />
