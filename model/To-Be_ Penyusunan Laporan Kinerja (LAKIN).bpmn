        <dc:Bounds x="730" y="790" width="250" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ann_terima_di" bpmnElement="ann_terima">
        <dc:Bounds x="1530" y="797" width="240" height="73" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf_start_input_di" bpmnElement="sf_start_input">
        <di:waypoint x="268" y="250" />
        <di:waypoint x="310" y="250" />
      </bpmndi:BPMNEdge>
