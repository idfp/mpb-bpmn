        <dc:Bounds x="1180" y="520" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_terima_lakin_di" bpmnElement="task_terima_lakin">
        <dc:Bounds x="1270" y="640" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_1_di" bpmnElement="end_1">
        <dc:Bounds x="1442" y="668" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1422" y="711" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_0tc1lbm_di" bpmnElement="Activity_0tc1lbm" isExpanded="false">
        <dc:Bounds x="1190" y="379" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
