      <bpmndi:BPMNShape id="task_verif_tracer_di" bpmnElement="task_verif_tracer">
        <dc:Bounds x="900" y="379" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_tracer_di" bpmnElement="gw_tracer" isMarkerVisible="true">
        <dc:Bounds x="1070" y="394" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1066" y="454" width="58" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
