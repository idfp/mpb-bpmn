<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <process id="ProsesGToBe" name="To-Be: Penyusunan Laporan Kinerja (LAKIN)" isExecutable="true" camunda:historyTimeToLive="180">
    <laneSet id="laneSet_1">
      <lane id="lane_wadek" name="Warek III (Penerima Laporan)">
        <flowNodeRef>task_terima_lakin</flowNodeRef>
        <flowNodeRef>end_1</flowNodeRef>
      </lane>
      <lane id="lane_sistem" name="Sistem Portal">
        <flowNodeRef>svc_request_tracer</flowNodeRef>
        <flowNodeRef>svc_notif_lakin</flowNodeRef>
      </lane>
      <lane id="lane_wdiii" name="WD III (Wakil Dekan Kemahasiswaan)">
        <flowNodeRef>task_verif_tracer</flowNodeRef>
        <flowNodeRef>gw_tracer</flowNodeRef>
        <flowNodeRef>Activity_0tc1lbm</flowNodeRef>
      </lane>
      <lane id="lane_fitri" name="Mbak Fitri (Staf Administrasi)">
        <flowNodeRef>start_1</flowNodeRef>
        <flowNodeRef>task_input_data</flowNodeRef>
        <flowNodeRef>task_siapkan_rekap</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="start_1" name="Awal Tahun: Mulai&#10;Input Data Kontinu">
      <outgoing>sf_start_input</outgoing>
    </startEvent>
    <userTask id="task_input_data" name="Input &#38; Update Data Kegiatan,&#10;Kerjasama &#38; Prestasi (Kontinu)" camunda:assignee="fitri">
      <incoming>sf_start_input</incoming>
      <outgoing>Flow_0tt9yjr</outgoing>
    </userTask>
    <userTask id="task_siapkan_rekap" name="Siapkan Rekap Data&#10;Lengkap untuk WD III" camunda:assignee="fitri">
      <incoming>Flow_0tt9yjr</incoming>
      <outgoing>sf_siapkan_request</outgoing>
    </userTask>
    <serviceTask id="svc_request_tracer" name="Kirim Request Data Tracer&#10;ke Platform CDE">
      <extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">http://217.217.254.115:8900/notify</camunda:inputParameter>
            <camunda:inputParameter name="method">POST</camunda:inputParameter>
            <camunda:inputParameter name="payload">{"recipient":"cde_platform","type":"tracer_data_request","processId":"${execution.processInstanceId}"}</camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">application/json</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </extensionElements>
      <incoming>sf_siapkan_request</incoming>
      <incoming>sf_tracer_tidak</incoming>
      <outgoing>sf_request_verif</outgoing>
    </serviceTask>
    <userTask id="task_verif_tracer" name="Verifikasi &#38; Terima&#10;Data Tracer dari CDE" camunda:assignee="wd3">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="dataTracerLengkap" label="Apakah data tracer tersedia dan lengkap?" type="boolean" defaultValue="false" />
        </camunda:formData>
      </extensionElements>
      <incoming>sf_request_verif</incoming>
      <outgoing>sf_verif_gw</outgoing>
    </userTask>
    <exclusiveGateway id="gw_tracer" name="Data Tracer&#10;Tersedia &#38; Lengkap?">
      <incoming>sf_verif_gw</incoming>
      <outgoing>sf_tracer_tidak</outgoing>
      <outgoing>Flow_0790cj4</outgoing>
    </exclusiveGateway>
    <serviceTask id="svc_notif_lakin" name="Kirim Notifikasi LAKIN&#10;ke Wadek III">
      <extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">http://217.217.254.115:8900/notify</camunda:inputParameter>
            <camunda:inputParameter name="method">POST</camunda:inputParameter>
            <camunda:inputParameter name="payload">{"recipient":"wadek3","type":"lakin_submission","processId":"${execution.processInstanceId}"}</camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">application/json</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </extensionElements>
      <incoming>Flow_0dlw5ir</incoming>
      <outgoing>sf_notif_terima</outgoing>
    </serviceTask>
    <userTask id="task_terima_lakin" name="Terima &#38; Tanda Terima&#10;LAKIN" camunda:assignee="wadek3">
      <incoming>sf_notif_terima</incoming>
      <outgoing>sf_terima_end</outgoing>
    </userTask>
    <endEvent id="end_1" name="LAKIN Diterima&#10;Wadek III">
      <incoming>sf_terima_end</incoming>
    </endEvent>
    <sequenceFlow id="sf_start_input" sourceRef="start_1" targetRef="task_input_data" />
    <sequenceFlow id="sf_siapkan_request" sourceRef="task_siapkan_rekap" targetRef="svc_request_tracer" />
    <sequenceFlow id="sf_request_verif" sourceRef="svc_request_tracer" targetRef="task_verif_tracer" />
    <sequenceFlow id="sf_verif_gw" sourceRef="task_verif_tracer" targetRef="gw_tracer" />
    <sequenceFlow id="sf_tracer_tidak" name="Tidak" sourceRef="gw_tracer" targetRef="svc_request_tracer">
      <conditionExpression xsi:type="tFormalExpression">${dataTracerLengkap == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_notif_terima" sourceRef="svc_notif_lakin" targetRef="task_terima_lakin" />
    <sequenceFlow id="sf_terima_end" sourceRef="task_terima_lakin" targetRef="end_1" />
    <subProcess id="Activity_0tc1lbm" name="Penyusunan LAKIN">
      <incoming>Flow_0790cj4</incoming>
      <outgoing>Flow_0dlw5ir</outgoing>
      <startEvent id="Event_08bvkfm">
        <outgoing>Flow_00p9bpl</outgoing>
      </startEvent>
      <userTask id="task_susun_lakin" name="Susun LAKIN per Bidang&#10;(Kemahasiswaan, Alumni, Kerjasama)" camunda:assignee="wd3">
        <incoming>Flow_00p9bpl</incoming>
        <outgoing>sf_susun_review</outgoing>
      </userTask>
      <userTask id="task_review_lakin" name="Review &#38; Finalisasi&#10;LAKIN" camunda:assignee="wd3">
        <incoming>sf_susun_review</incoming>
        <outgoing>Flow_05ifndc</outgoing>
      </userTask>
      <sequenceFlow id="sf_susun_review" sourceRef="task_susun_lakin" targetRef="task_review_lakin" />
      <sequenceFlow id="Flow_00p9bpl" sourceRef="Event_08bvkfm" targetRef="task_susun_lakin" />
      <endEvent id="Event_08v0390">
        <incoming>Flow_05ifndc</incoming>
      </endEvent>
      <sequenceFlow id="Flow_05ifndc" sourceRef="task_review_lakin" targetRef="Event_08v0390" />
    </subProcess>
    <sequenceFlow id="Flow_0790cj4" name="Ya" sourceRef="gw_tracer" targetRef="Activity_0tc1lbm">
      <conditionExpression xsi:type="tFormalExpression">${dataTracerLengkap == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_0dlw5ir" sourceRef="Activity_0tc1lbm" targetRef="svc_notif_lakin" />
    <sequenceFlow id="Flow_0tt9yjr" sourceRef="task_input_data" targetRef="task_siapkan_rekap" />
    <textAnnotation id="ann_input">
      <text>Data diinput via form portal sepanjang tahun; menggantikan input manual ke Google Sheet. Tiga komponen: KAK/LPJ, PKS &amp; IA, prestasi mahasiswa.</text>
    </textAnnotation>
    <association id="assoc_input" sourceRef="task_input_data" targetRef="ann_input" />
    <textAnnotation id="ann_tracer">
      <text>Request data tracer ke CDE via notification API; menggantikan koordinasi informal. Loop kembali jika data belum tersedia.</text>
    </textAnnotation>
    <association id="assoc_tracer" sourceRef="svc_request_tracer" targetRef="ann_tracer" />
    <textAnnotation id="ann_terima">
      <text>Penerimaan LAKIN terdokumentasi di sistem dengan tanda terima digital; menggantikan penyerahan hard copy manual</text>
    </textAnnotation>
    <association id="assoc_terima" sourceRef="task_terima_lakin" targetRef="ann_terima" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="ProsesGToBe">
      <bpmndi:BPMNShape id="lane_fitri_di" bpmnElement="lane_fitri" isHorizontal="true">
