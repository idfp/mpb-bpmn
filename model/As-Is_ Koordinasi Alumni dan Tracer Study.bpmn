      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf_start_koordinasi_di" bpmnElement="sf_start_koordinasi">
        <di:waypoint x="328" y="279" />
        <di:waypoint x="370" y="279" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf_to_split_di" bpmnElement="sf_to_split">
        <di:waypoint x="490" y="279" />
        <di:waypoint x="540" y="279" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf_koordinasi_kirimlink_di" bpmnElement="sf_koordinasi_kirimlink">
