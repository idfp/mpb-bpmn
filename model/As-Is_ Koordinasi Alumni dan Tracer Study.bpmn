<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <process id="ProsesDAsIs" name="As-Is: Koordinasi Alumni dan Tracer Study" isExecutable="false">
    <laneSet id="ls1">
      <lane id="lane_ikatan" name="Ikatan Alumni (Ketua)">
        <flowNodeRef>task_koordinasi_ikatan</flowNodeRef>
      </lane>
      <lane id="lane_cde" name="Platform CDE (Universitas)">
        <flowNodeRef>task_kirim_link</flowNodeRef>
        <flowNodeRef>task_kumpulkan_data</flowNodeRef>
        <flowNodeRef>msg_catch_data</flowNodeRef>
        <flowNodeRef>task_berikan_rekap</flowNodeRef>
      </lane>
      <lane id="lane_alumni" name="Alumni">
        <flowNodeRef>task_isi_tracer</flowNodeRef>
        <flowNodeRef>task_hadiri_forum</flowNodeRef>
        <flowNodeRef>msg_catch_link</flowNodeRef>
        <flowNodeRef>msg_throw_data</flowNodeRef>
      </lane>
      <lane id="lane_dosenpa" name="Dosen PA">
        <flowNodeRef>task_dosen_wa_alumni</flowNodeRef>
      </lane>
      <lane id="lane_wdiii" name="WD III (Wakil Dekan Kemahasiswaan)">
        <flowNodeRef>task_analisis_tracer</flowNodeRef>
        <flowNodeRef>task_undang_forum</flowNodeRef>
        <flowNodeRef>task_bahas_rtm</flowNodeRef>
        <flowNodeRef>task_lapor_wadek</flowNodeRef>
        <flowNodeRef>task_koordinasi_cde</flowNodeRef>
        <flowNodeRef>gw_parallel_split</flowNodeRef>
        <flowNodeRef>task_wa_alumni</flowNodeRef>
        <flowNodeRef>gw_peninjauan_kurikulum</flowNodeRef>
        <flowNodeRef>end_1</flowNodeRef>
        <flowNodeRef>start_1</flowNodeRef>
        <flowNodeRef>gw_respons_cukup</flowNodeRef>
        <flowNodeRef>gw_parallel_join</flowNodeRef>
        <flowNodeRef>task_request_rekap</flowNodeRef>
      </lane>
    </laneSet>
    <dataStoreReference id="ds_cde" name="Platform CDE&#10;(Universitas - Bu Catur)" />
    <dataStoreReference id="ds_sheet" name="Google Spreadsheet&#10;Monitoring" />
    <startEvent id="start_1" name="Periode Pengumpulan&#10;Data Tracer Study">
      <outgoing>sf_start_koordinasi</outgoing>
    </startEvent>
    <task id="task_koordinasi_cde" name="Koordinasi dengan Bu Catur (CDE)&#10;untuk Aktivasi Link Tracer">
      <incoming>sf_start_koordinasi</incoming>
      <outgoing>sf_to_split</outgoing>
    </task>
    <parallelGateway id="gw_parallel_split" name="Inisiasi&#10;Paralel">
      <incoming>sf_to_split</incoming>
      <outgoing>sf_koordinasi_kirimlink</outgoing>
      <outgoing>sf_koordinasi_wa</outgoing>
    </parallelGateway>
    <task id="task_kirim_link" name="Kirim Link Tracer Study&#10;ke Alumni (via Email)">
      <incoming>sf_koordinasi_kirimlink</incoming>
      <outgoing>sf_kirimlink_catch</outgoing>
      <dataOutputAssociation id="doa_cde1">
        <targetRef>ds_cde</targetRef>
      </dataOutputAssociation>
    </task>
    <intermediateCatchEvent id="msg_catch_link" name="Terima Link&#10;Tracer Study">
      <incoming>sf_kirimlink_catch</incoming>
      <outgoing>sf_catch_isitracer</outgoing>
      <messageEventDefinition id="med_catch_link" />
    </intermediateCatchEvent>
    <task id="task_isi_tracer" name="Isi Form&#10;Tracer Study">
      <incoming>sf_catch_isitracer</incoming>
      <outgoing>sf_isitracer_throw</outgoing>
    </task>
    <intermediateThrowEvent id="msg_throw_data" name="Submit Data&#10;Tracer">
      <incoming>sf_isitracer_throw</incoming>
      <outgoing>sf_throw_catchdata</outgoing>
      <messageEventDefinition id="med_throw_data" />
    </intermediateThrowEvent>
    <intermediateCatchEvent id="msg_catch_data" name="Terima Data&#10;Tracer Alumni">
      <incoming>sf_throw_catchdata</incoming>
      <outgoing>sf_catchdata_kumpulkan</outgoing>
      <messageEventDefinition id="med_catch_data" />
    </intermediateCatchEvent>
    <task id="task_kumpulkan_data" name="Kumpulkan &#38; Rekap&#10;Data Tracer">
      <incoming>sf_catchdata_kumpulkan</incoming>
      <outgoing>sf_kumpulkan_to_join</outgoing>
      <dataOutputAssociation id="doa_cde2">
        <targetRef>ds_cde</targetRef>
      </dataOutputAssociation>
    </task>
    <task id="task_wa_alumni" name="Hubungi Alumni Satu per Satu&#10;via WA (Personal)">
      <incoming>sf_koordinasi_wa</incoming>
      <outgoing>sf_wa_dosenpa</outgoing>
    </task>
    <task id="task_dosen_wa_alumni" name="Hubungi Alumni via WA&#10;(dari Dosen PA masing-masing)">
      <incoming>sf_wa_dosenpa</incoming>
      <outgoing>sf_dosenpa_to_join</outgoing>
    </task>
    <parallelGateway id="gw_parallel_join" name="Join&#10;Paralel">
      <incoming>sf_kumpulkan_to_join</incoming>
      <incoming>sf_dosenpa_to_join</incoming>
      <outgoing>sf_join_to_request</outgoing>
    </parallelGateway>
    <task id="task_request_rekap" name="Request Rekap Data Tracer&#10;dari Bu Catur (CDE)">
      <incoming>sf_join_to_request</incoming>
      <outgoing>sf_request_berikan</outgoing>
    </task>
    <task id="task_berikan_rekap" name="Berikan Rekap Data&#10;Tracer ke WD III">
      <incoming>sf_request_berikan</incoming>
      <outgoing>sf_berikan_gw</outgoing>
      <dataInputAssociation id="dia_cde1">
        <sourceRef>ds_cde</sourceRef>
      </dataInputAssociation>
    </task>
    <exclusiveGateway id="gw_respons_cukup" name="Respons Rate&#10;Cukup?">
      <incoming>sf_berikan_gw</incoming>
      <outgoing>sf_cukup_analisis</outgoing>
      <outgoing>sf_belum_wa</outgoing>
    </exclusiveGateway>
    <task id="task_analisis_tracer" name="Analisis Data Tracer Study&#10;(Pekerjaan, Bidang, dll.)">
      <incoming>sf_cukup_analisis</incoming>
      <outgoing>sf_analisis_gw_kurikulum</outgoing>
      <dataInputAssociation id="dia_sheet1">
        <sourceRef>ds_sheet</sourceRef>
      </dataInputAssociation>
    </task>
    <exclusiveGateway id="gw_peninjauan_kurikulum" name="Tahun Peninjauan&#10;Kurikulum? (2 thn)">
      <incoming>sf_analisis_gw_kurikulum</incoming>
      <outgoing>sf_ya_undang</outgoing>
      <outgoing>sf_tidak_rtm</outgoing>
    </exclusiveGateway>
    <task id="task_undang_forum" name="Undang Alumni &#38; Mitra Industri&#10;ke Forum Peninjauan Kurikulum">
      <incoming>sf_ya_undang</incoming>
      <outgoing>sf_undang_hadiri</outgoing>
    </task>
    <task id="task_hadiri_forum" name="Hadiri Forum Peninjauan&#10;Kurikulum">
      <incoming>sf_undang_hadiri</incoming>
      <outgoing>sf_hadiri_ikatan</outgoing>
    </task>
    <task id="task_koordinasi_ikatan" name="Koordinasi dengan Ketua&#10;Ikatan Alumni (Situasional)">
      <incoming>sf_hadiri_ikatan</incoming>
      <outgoing>sf_ikatan_rtm</outgoing>
    </task>
    <task id="task_bahas_rtm" name="Bahas Hasil Tracer di RTM&#10;(Rapat Tinjauan Manajemen)">
      <incoming>sf_tidak_rtm</incoming>
      <incoming>sf_ikatan_rtm</incoming>
      <outgoing>sf_rtm_lapor</outgoing>
    </task>
    <task id="task_lapor_wadek" name="Laporkan Data Tracer ke&#10;Wadek III / Input ke LAKIN">
      <incoming>sf_rtm_lapor</incoming>
      <outgoing>sf_lapor_end</outgoing>
    </task>
    <endEvent id="end_1" name="Data Tracer Selesai&#10;Dikumpulkan &#38; Dilaporkan">
      <incoming>sf_lapor_end</incoming>
    </endEvent>
    <sequenceFlow id="sf_start_koordinasi" sourceRef="start_1" targetRef="task_koordinasi_cde" />
    <sequenceFlow id="sf_to_split" sourceRef="task_koordinasi_cde" targetRef="gw_parallel_split" />
    <sequenceFlow id="sf_koordinasi_kirimlink" sourceRef="gw_parallel_split" targetRef="task_kirim_link" />
    <sequenceFlow id="sf_koordinasi_wa" sourceRef="gw_parallel_split" targetRef="task_wa_alumni" />
    <sequenceFlow id="sf_kirimlink_catch" sourceRef="task_kirim_link" targetRef="msg_catch_link" />
    <sequenceFlow id="sf_catch_isitracer" sourceRef="msg_catch_link" targetRef="task_isi_tracer" />
    <sequenceFlow id="sf_isitracer_throw" sourceRef="task_isi_tracer" targetRef="msg_throw_data" />
    <sequenceFlow id="sf_throw_catchdata" sourceRef="msg_throw_data" targetRef="msg_catch_data" />
    <sequenceFlow id="sf_catchdata_kumpulkan" sourceRef="msg_catch_data" targetRef="task_kumpulkan_data" />
    <sequenceFlow id="sf_kumpulkan_to_join" sourceRef="task_kumpulkan_data" targetRef="gw_parallel_join" />
    <sequenceFlow id="sf_wa_dosenpa" sourceRef="task_wa_alumni" targetRef="task_dosen_wa_alumni" />
    <sequenceFlow id="sf_dosenpa_to_join" sourceRef="task_dosen_wa_alumni" targetRef="gw_parallel_join" />
    <sequenceFlow id="sf_join_to_request" sourceRef="gw_parallel_join" targetRef="task_request_rekap" />
    <sequenceFlow id="sf_request_berikan" sourceRef="task_request_rekap" targetRef="task_berikan_rekap" />
    <sequenceFlow id="sf_berikan_gw" sourceRef="task_berikan_rekap" targetRef="gw_respons_cukup" />
    <sequenceFlow id="sf_cukup_analisis" name="Ya" sourceRef="gw_respons_cukup" targetRef="task_analisis_tracer">
      <conditionExpression>Respons rate cukup</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_belum_wa" name="Tidak" sourceRef="gw_respons_cukup" targetRef="gw_parallel_split">
      <conditionExpression>Respons belum cukup → kejar manual</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_analisis_gw_kurikulum" sourceRef="task_analisis_tracer" targetRef="gw_peninjauan_kurikulum" />
    <sequenceFlow id="sf_ya_undang" name="Ya" sourceRef="gw_peninjauan_kurikulum" targetRef="task_undang_forum">
      <conditionExpression>Ya (tahun peninjauan)</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_tidak_rtm" name="Tidak" sourceRef="gw_peninjauan_kurikulum" targetRef="task_bahas_rtm">
      <conditionExpression>Tidak (bukan tahun peninjauan)</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_undang_hadiri" sourceRef="task_undang_forum" targetRef="task_hadiri_forum" />
    <sequenceFlow id="sf_hadiri_ikatan" sourceRef="task_hadiri_forum" targetRef="task_koordinasi_ikatan" />
    <sequenceFlow id="sf_ikatan_rtm" sourceRef="task_koordinasi_ikatan" targetRef="task_bahas_rtm" />
    <sequenceFlow id="sf_rtm_lapor" sourceRef="task_bahas_rtm" targetRef="task_lapor_wadek" />
    <sequenceFlow id="sf_lapor_end" sourceRef="task_lapor_wadek" targetRef="end_1" />
    <textAnnotation id="ann_cde">
      <text>FIK tidak bisa akses data CDE secara mandiri; harus koordinasi langsung dengan Bu Catur di tingkat universitas</text>
    </textAnnotation>
    <association id="assoc_cde" sourceRef="task_koordinasi_cde" targetRef="ann_cde" />
    <textAnnotation id="ann_respons">
      <text>Respons alumni sangat rendah; banyak yang tidak mengisi meskipun sudah dikirim link</text>
    </textAnnotation>
    <association id="assoc_respons" sourceRef="task_isi_tracer" targetRef="ann_respons" />
    <textAnnotation id="ann_wa">
      <text>Pendekatan personal via WA efektif tapi tidak skalabel; tidak ada tim khusus tracer (berbeda dengan Fakultas Teknik yang sudah punya SK tim tracer)</text>
    </textAnnotation>
    <association id="assoc_wa" sourceRef="task_wa_alumni" targetRef="ann_wa" />
    <textAnnotation id="ann_kurikulum">
      <text>Peninjauan kurikulum dilakukan 2 tahun sekali; alumni diundang bersama mitra industri dan kerjasama untuk memberi masukan kebutuhan industri</text>
    </textAnnotation>
    <association id="assoc_kurikulum" sourceRef="task_undang_forum" targetRef="ann_kurikulum" />
    <textAnnotation id="ann_ikatan">
      <text>Koordinasi dengan Ikatan Alumni tidak terjadwal rutin; Ketua baru (Pak Arana) baru terpilih — berencana event besar untuk seluruh alumni</text>
    </textAnnotation>
    <textAnnotation id="ann_rtm">
      <text>Hasil tracer dan tindak lanjut dicatat di RTM tingkat fakultas; ini satu-satunya dokumentasi formal yang ada</text>
    </textAnnotation>
    <association id="assoc_rtm" sourceRef="task_bahas_rtm" targetRef="ann_rtm" />
    <association id="Association_01iiswz" associationDirection="None" sourceRef="ann_ikatan" targetRef="task_koordinasi_ikatan" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_D">
    <bpmndi:BPMNPlane id="BPMNPlane_D" bpmnElement="ProsesDAsIs">
      <bpmndi:BPMNShape id="lane_wdiii_di" bpmnElement="lane_wdiii" isHorizontal="true">
